# Line endings: LF everywhere, except Windows-native scripts that need CRLF
# to actually run (PowerShell and .bat files). The CRLF rule also matches
# the gradlew.bat that ships with the Gradle wrapper, so it stays runnable
# on Windows after a fresh clone.
*                 text=auto eol=lf
*.bat             text eol=crlf
*.cmd             text eol=crlf
*.ps1             text eol=crlf

# Binary files Git should not touch
*.jar             binary
*.png             binary
*.jpg             binary
*.gif             binary
*.ico             binary
