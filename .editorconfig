root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{java,kt,groovy}]
indent_size = 4

[*.{json,yml,yaml,toml}]
indent_size = 2

[*.{md,markdown}]
indent_size = 4
trim_trailing_whitespace = false

[*.gradle]
indent_size = 4

[Makefile]
indent_style = tab
